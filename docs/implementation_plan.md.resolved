### 2. Music Lesson Package Module

#### [NEW] [music.ts](file:///Users/pzps0964713/Documents/github/endaw-landingPage/src/data/music.ts)

Mock data structure for music lessons:

```typescript
interface Instrument {
  id: string;
  name: string;
  coverImage: string;
  description: string;
  containsEquipment: boolean;
  equipmentDescription?: string;
  rentalAvailable: boolean;
  rentalOffsetAllowed: boolean;
  levels: Level[];
}

interface Level {
  id: string;
  name: string; // e.g., "Beginner", "Intermediate"
  packages: Package[];
}

interface Package {
  id: string;
  name: string;
  lessonCount: number;
  bonusLessons: number; // Buy X get Y free
  validDuration: number; // Months
  firstClassDate: Date;
  registrationStartDates: Date[];
  formationRequired: boolean; // 拇指琴
  formationDecisionDays: number;
  refundPolicy: string;
  price: number;
  status: 'draft' | 'published';
  includedEquipment?: string[];
}

interface MonthlyAnnouncement {
  id: string;
  month: string; // "2026-03"
  instruments: string[];
  schedule: {
    date: Date;
    time: string;
    instructor: string;
  }[];
  announcements: string[];
}
```

